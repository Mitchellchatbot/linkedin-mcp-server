# ── Required ──────────────────────────────────────────────────────────────────

# Your LinkedIn OAuth 2.0 app credentials
# Create an app at https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# The public URL of this server (no trailing slash)
# On Railway this will be something like: https://linkedin-mcp-production.up.railway.app
BASE_URL=https://your-railway-app.up.railway.app

# ── Optional ──────────────────────────────────────────────────────────────────

# Random string used to sign session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-string

# If you already have a LinkedIn access token, paste it here to skip OAuth
# (Long-lived tokens last ~60 days)
# LINKEDIN_ACCESS_TOKEN=

# Server port (Railway sets this automatically)
# PORT=3000
